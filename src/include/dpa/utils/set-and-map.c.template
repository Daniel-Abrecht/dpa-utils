    dpa_u_giant_unsigned_int_t s = DPA__U_SM_BITMAP_BIT(key);
    bool r = *m & s;
    *m &= ~s;
    *value = that->value_list[key];
    that->value_list[key] = 0;
    return r;
  }
#endif
  struct lookup_result result = LOOKUP(that, key);
  if(!result.found){
    *value = 0;
